{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "es2020",

    "types": ["node", "jest"],

    "sourceMap": true,

    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "test",
    "e2e",
    "**/*.spec.ts",
    "**/*.e2e.ts"
  ]
}
